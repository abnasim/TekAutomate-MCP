# MCP Server environment variables
# Copy this file to .env and fill in your values.

# YOUR OpenAI API key — owns the vector store, never exposed to users.
# The /ai/responses-proxy endpoint uses this key for all Responses API calls.
OPENAI_SERVER_API_KEY=sk-proj-your-key-here

# Vector store created under OPENAI_SERVER_API_KEY's account.
# Run: node scripts/create-vector-store.js (or create via OpenAI dashboard)
COMMAND_VECTOR_STORE_ID=vs_xxxxxxxxxxxxxxxxxxxx

# Optional: override OpenAI base URL (for testing / proxies)
# OPENAI_BASE_URL=https://api.openai.com

# Optional: Hosted OpenAI Assistant ID for Assistants (Threads/Runs) API routing.
# Must be the full ID (e.g. asst_lda7NyuCT6Bv9lLUmZhx6uVU). Do not use placeholder "asst_...".
OPENAI_ASSISTANT_ID=asst_your_assistant_id_here

# Optional: Hosted assistant model override (default is gpt-4.1)
# OPENAI_ASSISTANT_MODEL=gpt-4.1

# Optional: Responses API max_output_tokens for direct (non-assistant) mode
# OPENAI_MAX_OUTPUT_TOKENS=12000

# Optional: MCP server port (default 8787)
# PORT=8787
