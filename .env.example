# TekAutomate MCP Server — environment variables
# Copy to .env and fill in your values.
# On Railway: set these in the Variables tab of your project.

# ── Required ────────────────────────────────────────────────────────────────

# Public URL of this MCP server (used for temp screenshot image URLs).
# Set to wherever this server is reachable — no trailing slash.
# Example (Railway):  https://tekautomate-mcp-production.up.railway.app
# Example (local):    http://localhost:8787
MCP_PUBLIC_URL=

# ── Live Instrument Control ──────────────────────────────────────────────────

# Keep false for the shared public instance — live instrument is user-specific.
# Set to true only for personal/local deployments with a real instrument connected.
LIVE_INSTRUMENT_ENABLED=false

# ── Optional ────────────────────────────────────────────────────────────────

# MCP server port (default: 8787). Railway sets PORT automatically.
# PORT=8787

# MCP Provider Supplements (enabled by default)
# MCP_PROVIDER_SUPPLEMENTS=false

# MCP Router
# MCP_ROUTER_DISABLED=true
