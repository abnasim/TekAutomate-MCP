# TekAutomate MCP Server — environment variables
# Copy to .env and fill in your values.
# On Railway: set these in the Variables tab of your project.

# ── Required ────────────────────────────────────────────────────────────────

# Public URL of this MCP server (used for temp screenshot image URLs).
# Set to wherever this server is reachable — no trailing slash.
# Example (Railway):  https://your-project.up.railway.app
# Example (local):    http://localhost:8787
MCP_PUBLIC_URL=

# OpenAI API key for AI features (build mode, chat, assistant).
OPENAI_API_KEY=

# OpenAI Assistant ID for hosted assistant mode.
# Get from OpenAI dashboard → Assistants.
OPENAI_ASSISTANT_ID=

# OpenAI Prompt ID for Responses API structured output.
# Get from OpenAI dashboard → Prompts.
OPENAI_PROMPT_ID=

# ── Live Instrument Control ──────────────────────────────────────────────────

# Set to true ONLY for personal/local deployments with a real instrument connected.
# Must be false for shared/hosted deployments — live instrument is user-specific.
LIVE_INSTRUMENT_ENABLED=false

# ── Optional ────────────────────────────────────────────────────────────────

# Override OpenAI base URL (for proxies or testing).
# OPENAI_BASE_URL=https://api.openai.com

# Override hosted assistant model (default: gpt-4.1).
# OPENAI_ASSISTANT_MODEL=gpt-4.1

# Override Responses API max output tokens (default: 12000).
# OPENAI_MAX_OUTPUT_TOKENS=12000

# MCP server port (default: 8787). Railway sets PORT automatically.
# PORT=8787

# Disable provider supplements (default: enabled).
# MCP_PROVIDER_SUPPLEMENTS=false

# Disable MCP router (default: enabled).
# MCP_ROUTER_DISABLED=false
