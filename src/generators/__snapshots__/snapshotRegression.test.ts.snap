exports[`snapshot regression full realistic workflow 1`] = `
"#!/usr/bin/env python3
\\"\\"\\"
Generated by TekAutomate
Backend: pyvisa
Host: 192.168.1.100
\\"\\"\\"
import argparse, time, pathlib
import pyvisa


def main():
    p = argparse.ArgumentParser()
    p.add_argument(\\"--visa\\", default=\\"TCPIP::192.168.1.100::INSTR\\")
    p.add_argument(\\"--timeout\\", type=float, default=5000)
    args = p.parse_args()
    
    print(f\\"Connecting via PyVISA to {args.visa}...\\")
    rm = pyvisa.ResourceManager()
    scpi = rm.open_resource(args.visa)
    scpi.timeout = int(args.timeout * 1000)
    scpi.write_termination = \\"\\\\n\\"
    scpi.read_termination = None  # binary safe
    
    idn = scpi.query(\\"*IDN?\\").strip()
    print(f\\"[OK] Connected: {idn}\\")

    def log_cmd(cmd, resp):
        pass

    scpi.write(\\"ACQ:STATE OFF\\")
    log_cmd(\\"ACQ:STATE OFF\\", \\"\\")
    _ = scpi.query(\\"*OPC?\\").strip()
    log_cmd(\\"*OPC?\\", _)
    time.sleep(0.2)
    scpi.write(\\"DATA:SOURCE CH1\\")
    log_cmd(\\"DATA:SOURCE CH1\\", \\"\\")
    scpi.write(\\"DATA:START 1\\")
    log_cmd(\\"DATA:START 1\\", \\"\\")
    scpi.write(\\"DATA:STOP 10000\\")
    log_cmd(\\"DATA:STOP 10000\\", \\"\\")
    waveform_data = scpi.query(\\"CURVE?\\").strip()
    log_cmd(\\"CURVE?\\", waveform_data)
    scpi.write(\\"ACQ:STATE ON\\")
    log_cmd(\\"ACQ:STATE ON\\", \\"\\")

    try:
        err = scpi.query('ALLEV?').strip()
        log_cmd('ALLEV?', err)
    except Exception:
        pass
    scpi.close()
    rm.close()
    print(\\"[OK] Complete\\")

if __name__ == \\"__main__\\":
    main()
"
`;

